// ====== Spinner ======
const SPIN = ["\u28CB", "\u28D9", "\u28F9", "\u28F8", "\u28FC", "\u28F4", "\u28E6", "\u28E7", "\u28C7", "\u28CF"];
let spinTimer = null;
let spinIdx = 0;

function startSpin(msg) {
  spinIdx = 0;
  spinTimer = setInterval(() => {
    process.stdout.write(`\r\x1b[90m${SPIN[spinIdx++ % SPIN.length]} ${msg}\x1b[0m`);
  }, 80);
}

function stopSpin() {
  if (spinTimer) {
    clearInterval(spinTimer);
    spinTimer = null;
    process.stdout.write("\r\x1b[K");
  }
}

// ====== Rate Limit ======
const MIN_INTERVAL = 1500;
let lastApiCall = 0;

function sleep(ms) {
  return new Promise((r) => setTimeout(r, ms));
}

function fetchWithTimeout(url, options, timeoutMs = 60000) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);
  return fetch(url, { ...options, signal: controller.signal }).finally(() =>
    clearTimeout(timer)
  );
}

async function rateLimitWait() {
  const elapsed = Date.now() - lastApiCall;
  if (elapsed < MIN_INTERVAL) {
    const waitMs = MIN_INTERVAL - elapsed;
    if (waitMs > 3000) {
      process.stdout.write(`\x1b[90m  (cooldown ${Math.ceil(waitMs / 1000)}s...)\x1b[0m\n`);
    }
    await sleep(waitMs);
  }
  // Note: lastApiCall is set AFTER response completes (in callGemini),
  // so streaming time counts toward the cooldown
}

function parseDuration(duration) {
  if (typeof duration !== "string") return null;
  if (duration.endsWith("ms")) {
    const ms = parseFloat(duration.slice(0, -2));
    return isNaN(ms) ? null : ms / 1000;
  }
  if (duration.endsWith("s")) {
    const sec = parseFloat(duration.slice(0, -1));
    return isNaN(sec) ? null : sec;
  }
  return null;
}

function parseRetryDelay(errText) {
  try {
    const json = JSON.parse(errText);
    const details = json.error?.details || [];
    // 1. Structured RetryInfo (protobuf style) - most reliable
    for (const d of details) {
      if (d["@type"]?.includes("RetryInfo") && d.retryDelay) {
        const sec = parseDuration(d.retryDelay);
        if (sec > 0) return sec;
      }
      // Fallback: plain retryDelay field
      if (d.retryDelay) {
        const sec = parseDuration(d.retryDelay) ?? parseInt(d.retryDelay);
        if (sec > 0) return sec;
      }
    }
    // 2. "Please retry in Xs" in message (Google API common format)
    const msg = json.error?.message || "";
    const pleaseRetry = msg.match(/(?:Please )?retry in ([0-9.]+(?:ms|s))/i);
    if (pleaseRetry) {
      const sec = parseDuration(pleaseRetry[1]);
      if (sec > 0) return sec;
    }
    // 3. "reset after Xs" format from Code Assist
    const resetMatch = msg.match(/reset after (\d+)s/i);
    if (resetMatch) return parseInt(resetMatch[1]);
  } catch {}
  // 4. Regex fallback on raw text
  const resetMatch = errText.match(/reset after (\d+)s/i);
  if (resetMatch) return parseInt(resetMatch[1]);
  const retryMatch = errText.match(/retry in ([0-9.]+(?:ms|s))/i);
  if (retryMatch) {
    const sec = parseDuration(retryMatch[1]);
    if (sec > 0) return sec;
  }
  return 0; // 0 = no server delay found (use client backoff)
}

function isTerminalQuota(errText) {
  try {
    const json = JSON.parse(errText);
    const details = json.error?.details || [];
    for (const d of details) {
      // Daily quota exhausted
      if (d.violations) {
        for (const v of d.violations) {
          if (v.quotaId?.includes("PerDay") || v.quotaId?.includes("Daily")) return true;
        }
      }
      // ErrorInfo: QUOTA_EXHAUSTED from Cloud Code
      if (d.reason === "QUOTA_EXHAUSTED" || d.reason === "INSUFFICIENT_G1_CREDITS_BALANCE") return true;
    }
  } catch {}
  return false;
}

