// ====== Character Width ======
function isWideChar(char) {
  if (!char) return false;
  const c = char.codePointAt(0);
  return (
    // Hangul Jamo
    (c >= 0x1100 && c <= 0x115F) ||
    (c >= 0x11A3 && c <= 0x11A7) ||
    (c >= 0x11FA && c <= 0x11FF) ||
    // CJK Radicals, Kangxi, Ideographic Description
    (c >= 0x2E80 && c <= 0x2FFF) ||
    // CJK Symbols and Punctuation (includes 。「」etc)
    (c >= 0x3000 && c <= 0x303E) ||
    // Hiragana + Katakana + Bopomofo + CJK Strokes + Katakana Ext
    (c >= 0x3040 && c <= 0x33BF) ||
    // CJK Unified Ideographs Extension A
    (c >= 0x3400 && c <= 0x4DBF) ||
    // CJK Unified Ideographs + Yi + Hangul
    (c >= 0x4E00 && c <= 0xD7FF) ||
    // CJK Compatibility Ideographs
    (c >= 0xF900 && c <= 0xFAFF) ||
    // Vertical forms + CJK Compatibility Forms + Small Forms
    (c >= 0xFE10 && c <= 0xFE6F) ||
    // Fullwidth forms (！～～)
    (c >= 0xFF01 && c <= 0xFF60) ||
    // Fullwidth currency symbols (￠￥etc)
    (c >= 0xFFE0 && c <= 0xFFE6) ||
    // CJK Ext B, C, D, E, F + CJK Compat Supplement
    (c >= 0x1F000 && c <= 0x1F9FF) || // Emoji (most are wide)
    (c >= 0x20000 && c <= 0x3FFFF)
  );
}

// ====== Multiline Input (raw stdin) ======
function readUserInput() {
  return new Promise((resolve) => {
    process.stdout.write("\x1b[32m> \x1b[0m");
    const lines = [""];
    let cursorPos = 0; // Character position within current line
    let partialBytes = null;

    process.stdin.setRawMode(true);
    process.stdin.resume();

    function cleanup() {
      process.stdin.removeListener("data", onData);
      process.stdin.setRawMode(false);
      process.stdin.pause();
    }

    function getPrefix() {
      return lines.length > 1 ? "\x1b[90m│\x1b[0m " : "\x1b[32m> \x1b[0m";
    }

    function redrawLine() {
      const prefix = getPrefix();
      const text = lines[lines.length - 1];
      const cols = process.stdout.columns || 80;
      const prefixLen = prefix.replace(/\x1b\[[^m]*m/g, "").length;
      const rendered = prefixLen + text.length;
      const wrappedLines = Math.ceil(rendered / cols) || 1;
      if (wrappedLines > 1) {
        process.stdout.write(`\x1b[${wrappedLines - 1}A`);
      }
      process.stdout.write(`\r\x1b[J` + prefix + text);
      // Move cursor back to correct position if not at end
      const charsAfter = [...text].length - cursorPos;
      if (charsAfter > 0) {
        process.stdout.write(`\x1b[${charsAfter}D`);
      }
    }

    function onData(data) {
      if (partialBytes) {
        data = Buffer.concat([partialBytes, data]);
        partialBytes = null;
      }

      for (let i = 0; i < data.length; i++) {
        const byte = data[i];

        // Ctrl+C - handled by SIGINT handler
        if (byte === 3) {
          continue;
        }

        // Ctrl+D - send
        if (byte === 4) {
          cleanup();
          process.stdout.write("\n");
          resolve(lines.join("\n"));
          return;
        }

        // Ctrl+A - move to start of line
        if (byte === 1) {
          cursorPos = 0;
          redrawLine();
          continue;
        }

        // Ctrl+E - move to end of line
        if (byte === 5) {
          cursorPos = [...lines[lines.length - 1]].length;
          redrawLine();
          continue;
        }

        // Ctrl+U - delete from cursor to start of line
        if (byte === 21) {
          const chars = [...lines[lines.length - 1]];
          lines[lines.length - 1] = chars.slice(cursorPos).join("");
          cursorPos = 0;
          redrawLine();
          continue;
        }

        // Enter
        if (byte === 13) {
          if (lines.length > 0 && lines[lines.length - 1] === "") {
            lines.pop();
            cleanup();
            process.stdout.write("\n");
            resolve(lines.join("\n"));
            return;
          }
          lines.push("");
          cursorPos = 0;
          process.stdout.write("\n\x1b[90m│\x1b[0m ");
          continue;
        }

        // Backspace
        if (byte === 127 || byte === 8) {
          if (cursorPos > 0) {
            const chars = [...lines[lines.length - 1]];
            chars.splice(cursorPos - 1, 1);
            lines[lines.length - 1] = chars.join("");
            cursorPos--;
            redrawLine();
          } else if (lines.length > 1) {
            lines.pop();
            const prevChars = [...lines[lines.length - 1]];
            cursorPos = prevChars.length;
            process.stdout.write("\x1b[2K\x1b[A");
            redrawLine();
          }
          continue;
        }

        // Delete key (Ctrl+D with content, or escape seq handled below)
        // Escape sequences
        if (byte === 27) {
          if (i + 2 < data.length && data[i + 1] === 91) {
            const code = data[i + 2];
            // Arrow Left
            if (code === 68) {
              if (cursorPos > 0) {
                cursorPos--;
                process.stdout.write("\x1b[D");
              }
              i += 2;
              continue;
            }
            // Arrow Right
            if (code === 67) {
              const chars = [...lines[lines.length - 1]];
              if (cursorPos < chars.length) {
                cursorPos++;
                process.stdout.write("\x1b[C");
              }
              i += 2;
              continue;
            }
            // Delete key: ESC [ 3 ~
            if (code === 51 && i + 3 < data.length && data[i + 3] === 126) {
              const chars = [...lines[lines.length - 1]];
              if (cursorPos < chars.length) {
                chars.splice(cursorPos, 1);
                lines[lines.length - 1] = chars.join("");
                redrawLine();
              }
              i += 3;
              continue;
            }
            // Home: ESC [ H
            if (code === 72) {
              cursorPos = 0;
              redrawLine();
              i += 2;
              continue;
            }
            // End: ESC [ F
            if (code === 70) {
              cursorPos = [...lines[lines.length - 1]].length;
              redrawLine();
              i += 2;
              continue;
            }
            // Skip other escape sequences
            i += 2;
            while (i < data.length && data[i] < 64) i++;
            continue;
          }
          // Bare ESC or ESC + unknown
          if (i + 1 < data.length) i++;
          continue;
        }

        // Regular UTF-8 character
        let charBytes = 1;
        if (byte >= 0xc0 && byte < 0xe0) charBytes = 2;
        else if (byte >= 0xe0 && byte < 0xf0) charBytes = 3;
        else if (byte >= 0xf0) charBytes = 4;
        else if (byte < 0x20) continue;

        if (i + charBytes > data.length) {
          partialBytes = data.slice(i);
          break;
        }

        const char = data.slice(i, i + charBytes).toString("utf-8");
        i += charBytes - 1;

        // Insert at cursor position
        const chars = [...lines[lines.length - 1]];
        chars.splice(cursorPos, 0, char);
        lines[lines.length - 1] = chars.join("");
        cursorPos++;

        // Optimize: if at end, just write char; otherwise redraw
        if (cursorPos === chars.length) {
          process.stdout.write(char);
        } else {
          redrawLine();
        }
      }
    }

    process.stdin.on("data", onData);
  });
}

