      const tc = history.filter((m) => m.parts?.some((p) => p.functionCall)).length;
      console.log(`\x1b[90mMessages: ${history.length} | Tool calls: ${tc} | Turns: ${turnCount}\x1b[0m`);
      continue;
    }
    if (input.startsWith("/model")) {
      const arg = input.split(/\s+/)[1];
